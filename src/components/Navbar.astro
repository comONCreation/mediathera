---
import { reader } from '../lib/keystatic'

const site = await reader.singletons.site.read()
const hero = await reader.singletons.hero.read()

const name = site?.name || 'Médiathéra'
const phone = site?.phone || ''
const phoneRaw = site?.phoneRaw || ''
const calendlyUrl = site?.calendlyUrl || '#'
const ctaText = hero?.ctaText || 'Prendre rendez-vous'

const links = [
  { href: '#a-propos', label: 'À propos' },
  { href: '#pour-qui', label: 'Pour qui ?' },
  { href: '#prestations', label: 'Prestations' },
  { href: '#contact', label: 'Contact' },
]
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-6 transition-all duration-500"
    id="navbar-inner"
    style="height:5rem"
  >
    <!-- Logo -->
    <a href="#" class="font-heading text-2xl text-stone-800 transition hover:text-primary">
      {name}
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 lg:flex">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="relative text-sm font-medium text-stone-600 transition hover:text-primary
                 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-0 after:bg-primary
                 after:transition-all after:duration-300 hover:after:w-full"
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Desktop CTA -->
    <div class="hidden items-center gap-5 lg:flex">
      <a
        href={`tel:${phoneRaw}`}
        class="text-sm text-stone-500 transition hover:text-primary"
      >
        {phone}
      </a>
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-stone-900
               shadow-lg shadow-primary/20 transition hover:bg-primary-dark hover:shadow-primary/30"
      >
        {ctaText}
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      id="menu-toggle"
      class="relative z-50 flex h-10 w-10 items-center justify-center rounded-lg lg:hidden"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span class="burger-lines flex w-5 flex-col gap-1.5">
        <span class="block h-0.5 w-full rounded bg-stone-700 transition-all duration-300"></span>
        <span class="block h-0.5 w-full rounded bg-stone-700 transition-all duration-300"></span>
        <span class="block h-0.5 w-full rounded bg-stone-700 transition-all duration-300"></span>
      </span>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay (outside <nav> to avoid backdrop-filter containing block) -->
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 top-0 z-40 opacity-0 transition-opacity duration-300 lg:hidden"
>
  <div class="absolute inset-0 bg-cream/90 backdrop-blur-md"></div>
  <div class="relative flex h-full flex-col items-center justify-center gap-8">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class="mobile-link font-heading text-3xl text-stone-800 transition hover:text-primary"
      >
        {label}
      </a>
    ))}
    <div
        class="mt-12 flex flex-col items-center gap-5 sm:flex-row sm:justify-center animate-fade-up"
        style="animation-delay:.8s"
    >
      <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 font-semibold text-stone-900
             shadow-xl shadow-primary/25 transition-all duration-300 hover:bg-primary-dark hover:shadow-primary/35 hover:-translate-y-0.5"
      >
        {ctaText}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
          href={`tel:${phoneRaw}`}
          class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white/60 px-6 py-4 text-sm font-medium text-stone-600
             backdrop-blur transition-all duration-300 hover:border-primary/40 hover:text-primary"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {phone}
      </a>
    </div>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar')!
  const toggle = document.getElementById('menu-toggle')!
  const menu = document.getElementById('mobile-menu')!
  const lines = toggle.querySelectorAll('.burger-lines span')
  let open = false

  /* Navbar scroll background */
  function onScroll() {
    const scrolled = window.scrollY > 60
    navbar.classList.toggle('bg-white/90', scrolled)
    navbar.classList.toggle('backdrop-blur-lg', scrolled)
    navbar.classList.toggle('shadow-sm', scrolled)
  }
  window.addEventListener('scroll', onScroll, { passive: true })
  onScroll()

  /* Mobile menu toggle */
  function toggleMenu() {
    open = !open
    menu.classList.toggle('opacity-0', !open)
    menu.classList.toggle('pointer-events-none', !open)
    menu.classList.toggle('opacity-100', open)
    menu.classList.toggle('pointer-events-auto', open)
    toggle.setAttribute('aria-expanded', String(open))
    document.body.style.overflow = open ? 'hidden' : ''

    /* Burger → X animation */
    if (open) {
      ;(lines[0] as HTMLElement).style.transform = 'rotate(45deg) translate(4px, 4px)'
      ;(lines[1] as HTMLElement).style.opacity = '0'
      ;(lines[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(4px, -4px)'
    } else {
      ;(lines[0] as HTMLElement).style.transform = ''
      ;(lines[1] as HTMLElement).style.opacity = '1'
      ;(lines[2] as HTMLElement).style.transform = ''
    }
  }

  toggle.addEventListener('click', toggleMenu)
  menu.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => {
      if (open) toggleMenu()
    })
  )
</script>
