---
type Variant = 'default' | 'highlight'

interface Props {
  variant?: Variant
  class?: string
}

const { variant = 'default', class: className = '' } = Astro.props

const variantClasses =
  variant === 'highlight'
    ? 'bg-primary text-white'
    : 'bg-primary-50 text-primary-dark'
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium ${variantClasses} ${className}`}
>
  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <slot name="icon" />
  </svg>
  <slot />
</span>
