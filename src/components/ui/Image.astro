---
import type { ImageMetadata } from 'astro'
import { Image as AstroImage } from 'astro:assets'

interface Props {
  src: ImageMetadata | null
  alt: string
  aspect?: string
  containerClass?: string
  widths?: number[]
  sizes?: string
  class?: string
}

const {
  src,
  alt,
  aspect = 'aspect-4/3',
  containerClass = 'bg-cream-dark',
  widths = [400, 600, 900, 1200],
  sizes = '(min-width: 768px) 50vw, 100vw',
  class: className = '',
} = Astro.props
---

<div class={`relative ${className}`}>
  <div class={`relative ${aspect} overflow-hidden rounded-3xl ${containerClass}`}>
    {src ? (
      <AstroImage
        src={src}
        alt={alt}
        widths={widths}
        sizes={sizes}
        class="h-full w-full object-cover"
      />
    ) : (
      <slot name="fallback" />
    )}
    <div class="pointer-events-none absolute inset-0 bg-linear-to-t from-primary/25 to-primary/10"></div>
  </div>
  <!-- Decorative frame offset -->
  <div
    class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-3xl border-2 border-primary/20"
  ></div>
  <!-- Decorative dot pattern -->
  <div class="absolute -left-6 -top-6 -z-10 grid grid-cols-3 gap-2">
    {Array.from({ length: 9 }).map(() => (
      <div class="h-2 w-2 rounded-full bg-primary/15"></div>
    ))}
  </div>
</div>
