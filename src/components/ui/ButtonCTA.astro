---
interface Props {
  href: string
  label: string
  size?: 'sm' | 'md'
  showIcon?: boolean
  class?: string
}

const { href, label, size = 'md', showIcon = true, class: className = '' } = Astro.props

const sizeClasses = {
  sm: 'px-5 py-2.5 text-sm shadow-lg shadow-primary/20 hover:shadow-primary/30',
  md: 'px-8 py-4 font-semibold shadow-xl shadow-primary/25 hover:shadow-primary/35 hover:-translate-y-0.5',
}
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'group inline-flex items-center gap-2 rounded-full bg-primary font-semibold text-stone-900 transition-all duration-300 hover:bg-primary-dark',
    sizeClasses[size],
    className,
  ]}
>
  {label}
  {showIcon && (
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
    </svg>
  )}
</a>
