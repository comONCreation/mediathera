---
import { reader } from '../lib/keystatic'

const about = await reader.singletons.about.read()

const name = about?.name || ''
const title = about?.title || ''
const bio = about?.bio || ''
const photo = about?.photo || null

const paragraphs = bio.split('\n\n').filter(Boolean)
---

<section id="a-propos" class="bg-white py-20 lg:py-28">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 md:grid-cols-2 md:gap-16 lg:gap-24">
    <!-- Photo -->
    <div class="reveal-left relative">
      <div class="relative aspect-3/4 overflow-hidden rounded-3xl bg-cream-dark">
        {photo ? (
          <img src={photo} alt={name} class="h-full w-full object-cover" />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-stone-300">
            <svg class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
        )}
      </div>
      <!-- Decorative frame offset -->
      <div
        class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-3xl border-2 border-primary/20"
      ></div>
      <!-- Decorative dot pattern -->
      <div class="absolute -left-6 -top-6 -z-10 grid grid-cols-3 gap-2">
        {Array.from({ length: 9 }).map(() => (
          <div class="h-2 w-2 rounded-full bg-primary/15"></div>
        ))}
      </div>
    </div>

    <!-- Bio -->
    <div class="reveal-right">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary">À propos</p>
      <h2 class="mt-3 font-heading text-4xl text-stone-800 lg:text-5xl">
        {name}
      </h2>
      <p class="mt-2 font-medium text-primary-dark">
        {title}
      </p>
      <div class="mt-2 h-px w-16 bg-primary/30"></div>
      {paragraphs.map((paragraph) => (
        <p class="mt-6 text-base leading-relaxed text-stone-600 lg:text-lg">
          {paragraph}
        </p>
      ))}
    </div>
  </div>
</section>
