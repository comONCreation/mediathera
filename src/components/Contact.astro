---
import { reader } from '../lib/keystatic'

const site = await reader.singletons.site.read()
const contactData = await reader.singletons.contact.read()

const phone = site?.phone || ''
const phoneRaw = site?.phoneRaw || ''
const email = site?.email || ''
const calendlyUrl = site?.calendlyUrl || '#'
const instagramUrl = site?.instagramUrl || null
const facebookUrl = site?.facebookUrl || null
const linkedinUrl = site?.linkedinUrl || null

const heading = contactData?.heading || 'Prenez rendez-vous'
const mapEmbedUrl = contactData?.mapEmbedUrl || ''
---

<section id="contact" class="bg-stone-900 py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <p class="reveal text-sm font-semibold uppercase tracking-widest text-primary-light">
        Contact
      </p>
      <h2 class="reveal mt-3 font-heading text-4xl text-cream">
        {heading}
      </h2>
      <div class="reveal mx-auto mt-4 h-px w-16 bg-primary/40"></div>
    </div>

    <div class="mt-16 grid gap-12 md:grid-cols-2 lg:gap-20">
      <!-- Contact info -->
      <div class="reveal-left">
        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-stone-400">Téléphone</p>
            <a href={`tel:${phoneRaw}`} class="mt-1 text-lg text-cream transition hover:text-primary">
              {phone}
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="mt-8 flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-stone-400">Email</p>
            <a href={`mailto:${email}`} class="mt-1 text-lg text-cream transition hover:text-primary">
              {email}
            </a>
          </div>
        </div>

        <!-- Social links -->
        {(instagramUrl || facebookUrl || linkedinUrl) && (
          <div class="mt-10">
            <p class="text-sm font-medium text-stone-400">Réseaux sociaux</p>
            <div class="mt-3 flex gap-3">
              {instagramUrl && (
                <a
                  href={instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram"
                  class="flex h-11 w-11 items-center justify-center rounded-xl bg-stone-800 text-stone-400 transition hover:bg-primary hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              )}
              {facebookUrl && (
                <a
                  href={facebookUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Facebook"
                  class="flex h-11 w-11 items-center justify-center rounded-xl bg-stone-800 text-stone-400 transition hover:bg-primary hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
              )}
              {linkedinUrl && (
                <a
                  href={linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="LinkedIn"
                  class="flex h-11 w-11 items-center justify-center rounded-xl bg-stone-800 text-stone-400 transition hover:bg-primary hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        )}

        <!-- CTA -->
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group mt-10 inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 font-semibold text-stone-900
                 shadow-xl shadow-primary/20 transition-all duration-300 hover:bg-primary-dark hover:-translate-y-0.5"
        >
          Prendre rendez-vous
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <!-- Map -->
      <div class="reveal-right">
        <div class="aspect-4/3 overflow-hidden rounded-2xl bg-stone-800">
          {mapEmbedUrl ? (
            <iframe
              src={mapEmbedUrl}
              width="100%"
              height="100%"
              style="border:0"
              allowfullscreen
              loading="lazy"
            ></iframe>
          ) : (
            <div class="flex h-full w-full flex-col items-center justify-center gap-3 text-stone-500">
              <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
              </svg>
              <span class="text-sm">Google Maps</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
