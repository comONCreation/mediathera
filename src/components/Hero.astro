---
import { reader } from '../lib/keystatic'

const site = await reader.singletons.site.read()
const hero = await reader.singletons.hero.read()

const name = site?.name || 'Médiathéra'
const phone = site?.phone || ''
const phoneRaw = site?.phoneRaw || ''
const calendlyUrl = site?.calendlyUrl || '#'

const tagline = hero?.tagline || ''
const motto = hero?.motto || ''
const ctaText = hero?.ctaText || 'Prendre rendez-vous'
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-linear-to-br from-cream via-primary-50 to-cream-dark"></div>

  <!-- Decorative blurred orbs -->
  <div class="absolute -left-24 top-1/4 h-120 w-120 rounded-full bg-primary/8 blur-3xl"></div>
  <div class="absolute -right-24 bottom-1/4 h-144 w-xl rounded-full bg-primary/5 blur-3xl"></div>
  <div class="absolute left-1/2 top-16 h-48 w-48 -translate-x-1/2 rounded-full bg-primary-light/20 blur-2xl"></div>

  <!-- Content -->
  <div class="relative z-10 px-6 text-center">
    <!-- Small decorative line -->
    <div class="mx-auto mb-8 h-px w-16 bg-primary/40 animate-fade-in" style="animation-delay:.1s"></div>

    <h1 class="animate-fade-up" style="animation-delay:.2s">
      <span class="sr-only">{name}</span>
      <img
        src="/images/logo_full.webp"
        alt={name}
        class="mx-auto h-auto w-60 md:w-80"
      />
    </h1>

    <p
      class="mx-auto mt-5 max-w-xl text-lg text-stone-500 md:text-xl animate-fade-up"
      style="animation-delay:.4s"
    >
      {tagline}
    </p>

    <p
      class="mt-10 font-heading text-2xl text-primary-dark md:text-3xl animate-fade-up"
      style="animation-delay:.6s"
    >
      {motto}
    </p>

    <div
      class="mt-12 flex flex-col items-center gap-5 sm:flex-row sm:justify-center animate-fade-up"
      style="animation-delay:.8s"
    >
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 font-semibold text-stone-900
               shadow-xl shadow-primary/25 transition-all duration-300 hover:bg-primary-dark hover:shadow-primary/35 hover:-translate-y-0.5"
      >
        {ctaText}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href={`tel:${phoneRaw}`}
        class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white/60 px-6 py-4 text-sm font-medium text-stone-600
               backdrop-blur transition-all duration-300 hover:border-primary/40 hover:text-primary"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {phone}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll-indicator"
    class="absolute bottom-18 left-1/2 -translate-x-1/2 transition-all duration-300 ease-out"
  >
    <a
      href="#a-propos"
      class="flex flex-col items-center gap-2 text-stone-400 transition hover:text-primary animate-fade-in"
      style="animation-delay:1.2s"
      aria-label="Défiler vers le bas"
    >
      <span class="text-xs font-medium uppercase tracking-widest">Découvrir</span>
      <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>

  <!-- Wave divider -->
  <div class="absolute -bottom-px left-0 right-0 text-white">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block h-16 w-full md:h-24">
      <path d="M0 40C240 80 480 0 720 40C960 80 1200 20 1440 50V100H0V40Z" fill="currentColor" />
    </svg>
  </div>
</section>

<script>
  const scrollIndicator = document.getElementById('hero-scroll-indicator')

  if (scrollIndicator) {
    const indicator = scrollIndicator
    const scrollIndicatorLink = indicator.querySelector('a')

    function updateScrollIndicator() {
      const hideAfter = Math.max(80, window.innerHeight * 0.12)
      const hidden = window.scrollY > hideAfter

      indicator.classList.toggle('opacity-0', hidden)
      indicator.classList.toggle('pointer-events-none', hidden)
      indicator.classList.toggle('translate-y-2', hidden)
      indicator.setAttribute('aria-hidden', String(hidden))

      if (hidden) {
        scrollIndicatorLink?.setAttribute('tabindex', '-1')
      } else {
        scrollIndicatorLink?.removeAttribute('tabindex')
      }
    }

    window.addEventListener('scroll', updateScrollIndicator, { passive: true })
    window.addEventListener('resize', updateScrollIndicator)
    updateScrollIndicator()
  }
</script>
