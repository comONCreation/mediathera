---
import { reader } from '../lib/keystatic'
import Modal from './ui/Modal.astro'

const site = await reader.singletons.site.read()
const name = site?.name || 'Médiathéra'
const legalNotice = site?.legalNotice || ''
const year = new Date().getFullYear()
---

<footer class="bg-stone-950 py-10">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-6 text-center md:flex-row md:justify-between md:text-left">
    <a href="#" class="font-heading text-xl text-stone-400 transition hover:text-primary">
      {name}
    </a>
    <p class="text-sm text-stone-400">
      &copy; {year} {name} - Tous droits réservés
    </p>
    <Modal title="Mentions légales">
      <button
        slot="trigger"
        type="button"
        data-modal-trigger
        class="cursor-pointer text-sm text-stone-400 transition hover:text-stone-300"
      >
        Mentions légales
      </button>
      <div class="whitespace-pre-wrap">{legalNotice || 'Mentions légales à compléter.'}</div>
    </Modal>
  </div>
</footer>
